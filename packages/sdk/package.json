    "@aztec/l1-artifacts": "4.0.0-devnet.2-patch.3",
    "@aztec/stdlib": "4.0.0-devnet.2-patch.3",
    "@aztec/wallet-sdk": "4.0.0-devnet.2-patch.3",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "axios": "^1.13.6",
    "siwe": "^3.0.0",
    "viem": "^2.22.8"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5"
