# ─── Required ──────────────────────────────────────────────────────────────────

# Wallet mnemonic (controls L1 account that deploys contracts and funds bridges)
MNEMONIC="your twelve word mnemonic phrase goes here"

# L1 RPC URL (e.g. Alchemy, Infura)
L1_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ─── Environment ───────────────────────────────────────────────────────────────

# "devnet" or "sandbox" (default: sandbox)
AZTEC_ENV=devnet

# L1 chain ID (11155111 = Sepolia, 1337 = local anvil)
L1_CHAIN_ID=11155111

# Aztec bootnode URL
BOOTNODE=https://v4-devnet-2.aztec-labs.com

# ─── Compliant Bridge Keys ────────────────────────────────────────────────────
# Private keys for attestation signers. Required for the compliant bridge script.
# Can be with or without 0x prefix.
# Falls back to hardhat test keys if not set (DO NOT use defaults in production).

POCH_ATTESTER_PRIVATE_KEY=
PASSPORT_SIGNER_PRIVATE_KEY=

# ─── Compliant Bridge Config ──────────────────────────────────────────────────

# Fee charged on deposits (basis points, 500 = 5%)
FEE_BASIS_POINTS=500

# Circuit ID for clean-hands attestation
CLEAN_HANDS_CIRCUIT_ID=1

# Amount to mint for testing (in token base units, default 1e15)
MINT_AMOUNT=1000000000000000

# ─── Passport / External Services ─────────────────────────────────────────────

PASSPORT_API_KEY=
PASSPORT_SCORER_ID=
PASSPORT_ATTESTOR_PRIVATE_KEY=

# ─── Run Mode (compliant script only) ─────────────────────────────────────────
# These control what the compliant script does. All default to false/empty.

# Skip deployment, only run tests against existing tokens
# RUN_TESTS_ONLY=true

# Deploy tokens but skip tests
# DEPLOY_ONLY=true

# Only deploy a specific token (others skipped even if new). Case-insensitive.
# DEPLOY_TOKEN=USDC
