{
"name": "src",
"version": "1.0.0",
"main": "index.js",
"license": "MIT",
"private": true,
"type": "module",
"scripts": {
"start": "node --import tsx index.ts",
"start-testnet": "LOG_LEVEL='silent;info:bridge' node --import tsx index-testnet.ts",
"start-testnet:compliant": "node --import tsx index-testnet-compliant.ts",
"deploy-testnet:compliant": "DEPLOY_ONLY=true node --import tsx index-testnet-compliant.ts",
"deploy-testnet:compliant:token": "DEPLOY_ONLY=true DEPLOY_TOKEN=${TOKEN} node --import tsx index-testnet-compliant.ts",
"test-testnet:compliant": "RUN_TESTS_ONLY=true node --import tsx index-testnet-compliant.ts",
"profile-testnet:compliant": "PROFILE=true RUN_TESTS_ONLY=true node --import tsx index-testnet-compliant.ts",
"test": "jest",
"fees": "node --loader ts-node/esm scripts/fees.ts",
"clean": "rm -rf ./src/artifacts ./target",
"clear-store": "rm -rf ./store",
"codegen": "aztec codegen ../aztec-contracts/token_bridge/target --outdir artifacts && aztec codegen ../aztec-contracts/token_minter_proxy/target --outdir artifacts",
"compile": "cd ../aztec-contracts/token_bridge && aztec compile && cd ../token_minter_proxy && aztec compile",
"compile:l1": "cd ../l1-contracts && forge build",
"build": "pnpm run compile && pnpm run compile:l1 && pnpm run codegen",
"deploy-contract": "node --import tsx deploy-contract.ts",
"deploy-account": "node --loader ts-node/esm scripts/deploy-account.ts",
"get-block": "node --loader ts-node/esm scripts/getBlock.ts",
"test:js": "NODE_NO_WARNINGS=1 node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --config jest.integration.config.json",
"test:nr": "aztec test"
},
"dependencies": {
"@aztec/accounts": "4.2.0-aztecnr-rc.2",
"@aztec/aztec.js": "4.2.0-aztecnr-rc.2",
"@aztec/constants": "4.2.0-aztecnr-rc.2",
"@aztec/ethereum": "4.2.0-aztecnr-rc.2",
"@aztec/foundation": "4.2.0-aztecnr-rc.2",
"@aztec/kv-store": "4.2.0-aztecnr-rc.2",
"@aztec/l1-artifacts": "4.2.0-aztecnr-rc.2",
"@aztec/noir-contracts.js": "4.2.0-aztecnr-rc.2",
"@aztec/protocol-contracts": "4.2.0-aztecnr-rc.2",
"@aztec/pxe": "4.2.0-aztecnr-rc.2",
"@aztec/stdlib": "4.2.0-aztecnr-rc.2",
"@aztec/wallets": "4.2.0-aztecnr-rc.2",
"@defi-wonderland/aztec-standards": "https://github.com/defi-wonderland/aztec-standards/releases/download/prerelease-1ad0e28/defi-wonderland-aztec-standards-4.2.0-aztecnr-rc.2-prerelease.1ad0e28.tgz",
"@types/node": "^22.13.10",
"dotenv": "^16.5.0",
"tsx": "^4.19.3",
"typescript": "^5.0.4",
"viem": "2.23.7"
},
"devDependencies": {
"@types/jest": "^29.5.11",
"@types/mocha": "^10.0.6",
"@types/node": "^22.5.1",
"jest": "^29.7.0",
"ts-jest": "^29.1.1",
"ts-node": "^10.9.2",
"typescript": "^5.4.4"
}
}
