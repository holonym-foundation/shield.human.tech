{
  "name": "src",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx index.ts",
    "start-devnet": "LOG_LEVEL='silent;info:bridge' node --import tsx index-devnet.ts",
    "start-devnet:compliant": "node --import tsx index-devnet-compliant.ts",
    "deploy-devnet:compliant": "DEPLOY_ONLY=true node --import tsx index-devnet-compliant.ts",
    "deploy-devnet:compliant:token": "DEPLOY_ONLY=true DEPLOY_TOKEN=${TOKEN} node --import tsx index-devnet-compliant.ts",
    "test-devnet:compliant": "RUN_TESTS_ONLY=true node --import tsx index-devnet-compliant.ts",
    "test-devnet:compliant:fuel-only": "RUN_TESTS_ONLY=true SKIP_TO_FUEL_TESTS=true node --import tsx index-devnet-compliant.ts",
    "profile-devnet:compliant": "PROFILE=true RUN_TESTS_ONLY=true node --import tsx index-devnet-compliant.ts",
    "e2e-devnet:compliant": "FORCE_REDEPLOY_ALL=true node --import tsx index-devnet-compliant.ts",
    "redeploy-devnet:compliant:swaps": "FORCE_REDEPLOY_SWAPS=true DEPLOY_ONLY=true node --import tsx index-devnet-compliant.ts",
    "reseed-devnet:compliant:pools": "FORCE_SEED=true DEPLOY_ONLY=true node --import tsx index-devnet-compliant.ts",
    "seed-pools": "LOG_LEVEL='silent;info:seed-pools' node --import tsx seed-pools.ts",
    "check-pools": "LOG_LEVEL='silent;info:check-pools' node --import tsx check-pool-liquidity.ts",
    "test-fuel-swap": "LOG_LEVEL='silent;info:test-fuel-swap' node --import tsx test-fuel-swap.ts",
    "set-trusted-forwarders": "LOG_LEVEL='silent;info:set-forwarders' node --import tsx set-trusted-forwarders.ts",
    "deploy-fuel-swap": "LOG_LEVEL='silent;info:deploy-fuel-swap' node --import tsx deploy-fuel-swap.ts",
    "deploy-swap-router": "LOG_LEVEL='silent;info:deploy-swap-router' node --import tsx deploy-swap-router.ts",
    "deploy-token-portal": "LOG_LEVEL='silent;info:deploy-token-portal' node --import tsx deploy-token-portal.ts",
    "redeploy-permit2": "LOG_LEVEL='silent;info:bridge' node --import tsx redeploy-permit2.ts",
    "test": "jest",
    "fees": "node --loader ts-node/esm scripts/fees.ts",
    "clean": "rm -rf ./src/artifacts ./target",
    "clear-store": "rm -rf ./store",
    "codegen": "aztec codegen ../aztec-contracts/token_bridge/target --outdir artifacts && aztec codegen ../aztec-contracts/token_minter_proxy/target --outdir artifacts",
    "compile": "cd ../aztec-contracts/token_bridge && aztec compile && cd ../token_minter_proxy && aztec compile",
    "compile:l1": "cd ../l1-contracts && forge build",
    "build": "pnpm run compile && pnpm run compile:l1 && pnpm run codegen",
    "deploy-contract": "node --import tsx deploy-contract.ts",
    "deploy-account": "node --loader ts-node/esm scripts/deploy-account.ts",
    "get-block": "node --loader ts-node/esm scripts/getBlock.ts",
    "test:js": "NODE_NO_WARNINGS=1 node --experimental-vm-modules $(yarn bin jest) --no-cache --runInBand --config jest.integration.config.json",
    "test:nr": "aztec test"
  },
  "dependencies": {
    "@aztec/accounts": "4.0.0-devnet.2-patch.2",
    "@aztec/aztec.js": "4.0.0-devnet.2-patch.2",
    "@aztec/constants": "4.0.0-devnet.2-patch.2",
    "@aztec/ethereum": "4.0.0-devnet.2-patch.2",
    "@aztec/foundation": "4.0.0-devnet.2-patch.2",
    "@aztec/kv-store": "^4.0.0-devnet.2-patch.2",
    "@aztec/l1-artifacts": "4.0.0-devnet.2-patch.2",
    "@aztec/noir-contracts.js": "4.0.0-devnet.2-patch.2",
    "@aztec/protocol-contracts": "4.0.0-devnet.2-patch.2",
    "@aztec/pxe": "4.0.0-devnet.2-patch.2",
    "@aztec/stdlib": "4.0.0-devnet.2-patch.2",
    "@aztec/wallets": "4.0.0-devnet.2-patch.2",
    "@defi-wonderland/aztec-fee-payment": "https://github.com/defi-wonderland/aztec-fee-payment/releases/download/prerelease-b6315f1/defi-wonderland-aztec-fee-payment-4.0.0-devnet.2-patch.1-prerelease.b6315f1.tgz",
    "@defi-wonderland/aztec-standards": "4.0.0-devnet.2-patch.1",
    "@types/node": "^22.13.10",
    "dotenv": "^16.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.0.4",
    "viem": "2.23.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.5.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.4"
  }
}
