{
  "name": "l1-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:e2e": "forge test --match-contract E2EPoolSeedAndSwapTest -vvv",
    "test:fuel-swap": "forge test --match-path src/test/UniswapFuelSwap.t.sol -vvv",
    "test:gas": "forge test --gas-report",
    "clean": "forge clean",
    "fmt": "forge fmt",
    "fmt:check": "forge fmt --check",
    "snapshot": "forge snapshot",
    "coverage": "forge coverage",
    "deploy:fuel-swap": "forge script script/DeployUniswapFuelSwap.s.sol:DeployUniswapFuelSwap --rpc-url $L1_URL --broadcast --slow -vvv",
    "deploy:swap-router": "forge script script/DeploySwapBridgeRouter.s.sol:DeploySwapBridgeRouter --rpc-url $L1_URL --broadcast --slow --verify -vvv",
    "deploy:token-portal": "forge script script/DeployTokenPortalWithForwarder.s.sol:DeployTokenPortalWithForwarder --rpc-url $L1_URL --broadcast --slow --verify -vvv",
    "seed-pools": "forge script script/SeedUniswapPools.s.sol:SeedUniswapPools --rpc-url $L1_URL --broadcast --slow -vvv",
    "set-trusted-forwarders": "forge script script/SetTrustedForwarderAllPortals.s.sol:SetTrustedForwarderAllPortals --rpc-url $L1_URL --broadcast --slow -vvv"
  }
}
