# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/aztec_bridge"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"

# ─── L1 / Ethereum ────────────────────────────────────────────────────────────
ETHEREUM_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"
FAUCET_PRIVATE_KEY="0x..."

# ─── WalletConnect ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# ─── Attestation: POCH (Clean Hands) ──────────────────────────────────────────
# Private key of the attester that signs clean-hands attestations.
# Must match the humanIdAttester address configured in the L1 TokenPortal contract.
POCH_ATTESTER_PRIVATE_KEY=""

# Circuit ID for clean-hands attestation (must match L1/L2 contract config)
CLEAN_HANDS_CIRCUIT_ID="1"

# Action ID for Holonym API (default: 123456789)
CLEAN_HANDS_ACTION_ID="123456789"

# Holonym API base URL (default: https://api.holonym.io)
# HOLONYM_API_URL="https://api.holonym.io"

# ─── Attestation: Passport ────────────────────────────────────────────────────
# Private key of the signer for passport-based max-amount attestations.
# Must match the passportSigner address configured in the L1 TokenPortal contract.
PASSPORT_SIGNER_PRIVATE_KEY=""

# L2 Grumpkin keys for Schnorr attestation (must match L2 bridge contract config)
L2_POCH_ATTESTER_PRIVATE_KEY=""
L2_PASSPORT_SIGNER_PRIVATE_KEY=""

# Gitcoin Passport API credentials
PASSPORT_API_KEY=""
PASSPORT_SCORER_ID=""

# Minimum passport score to qualify (default: 20)
PASSPORT_SCORE_THRESHOLD="20"

# Max deposit amount for passport attestation (in token base units, default: 1e9 = 1000 USDC)
PASSPORT_MAX_AMOUNT="1000000000"
